# --- LLM provider (Cloud.ru FM API) ---
# Один ключ работает для qwen-coder, minimax, glm моделей.
LLM_API_KEY=
# Можно переопределить если используешь cloudru-proxy (default https://foundation-models.api.cloud.ru/v1).
# MANUS_CLOUDRU_BASE=https://foundation-models.api.cloud.ru/v1

# --- (optional) Cloud.ru ML Inference vLLM ---
# Полный URL твоего vLLM-deployment, обязательно если используешь модель qwen35-vlm.
# MANUS_VLM_BASE=https://<your-deployment-uuid>.modelrun.inference.cloud.ru/v1

# --- (optional) Telegram bridge (message_notify_user / message_ask_user) ---
# Без этих переменных тулы fallback'ятся на stdin/stdout.
# MANUS_TG_BOT_TOKEN=
# MANUS_TG_USER_ID=

# --- (optional) PAC1 benchmark (bitgn) ---
# BITGN_API_KEY=
# BITGN_HOST=https://api.bitgn.com

# --- (optional) Behavior toggles (debug/dev) ---
# MANUS_DISABLE_MASKING=1     # отключить sanitization секретов в session.jsonl/observations
# MANUS_KEEP_TMUX=1            # не убивать tmux-сессии при выходе
# MANUS_KEEP_ASYNC_CHILDREN=1  # не убивать async sub-agents при atexit
# MANUS_CRITIC_MODE=loose      # off | loose (default loose)
# MANUS_SUBAGENT_RECURSION_DEPTH=2
